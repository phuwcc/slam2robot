      <!-- Cụm 5 -->
      <link name="l_door_5"><pose>34 1.4 1.0 0 0 0</pose><collision name="c"><geometry><box><size>1.0 0.1 2.0</size></box></geometry></collision><visual name="v"><geometry><box><size>1.0 0.1 2.0</size></box></geometry><material><script><uri>file://media/materials/scripts/gazebo.material</uri><name>Gazebo/Wood</name></script></material></visual></link>
